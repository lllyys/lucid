# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Test / coverage
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
*.local
.vite/

# nlpm generated artifacts
.claude/nlpm-history.json

# tdd-guardian runtime state (generated by the TDD hook)
.claude/tdd-guardian/state.json

# Local persistence / DB — the self-hosted sync server's SQLite (keep server data out of git)
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite3

# Local env / secrets — never commit real keys (rule 65 §5; runtime keys are in-memory anyway)
.env.local
.env.*.local

# bureau rendered board (regenerated by bureau:inspect)
/gazette/

# Agent dispatch — worktrees and per-job overflow reports (dispatch skill)
.claude/worktrees/
.reports/
